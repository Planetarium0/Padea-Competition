#!/usr/bin/bash
# ------------------------------------------------------------
# run – simple command‑line shortcut for Padea operations
# ------------------------------------------------------------

# Directory containing migration scripts (relative to repository root)
MIGRATION_DIR="scripts/migrations"
SCRIPTS_DIR="scripts"

# Make both `scripts/` (so `support`, `actions`, etc. resolve as packages)
# and the project root (so `data.*` resolves) importable.
export PYTHONPATH=$PYTHONPATH:"$PWD":"$PWD"/"$SCRIPTS_DIR"

# Helper to show usage
function usage() {
    cat <<EOF
Usage:
  $0 migrate [resource]
  $0 schema update
  $0 script [name]
  $0 test [name]
  $0 orders
  $0 orders generate [--dry-run]
  $0 orders preview
  $0 orders send
  $0 host [--port PORT]
  $0 qr [--origin URL_ORIGIN] [--base-url URL] [--session ID]

resource can be one of:
  diet, caterers, contacts, menus, sessions, students, absences, exclusions, all

If no resource is supplied, all migrations are run.
EOF
}

# Resolve short resource names to script filenames
declare -A RES_MAP=(
    [diet]="dietary_restrictions.py"
    [caterers]="caterers.py"
    [contacts]="caterer_contacts.py"
    [menus]="caterer_menus.py"
    [sessions]="sessions.py"
    [students]="students.py"
    [absences]="absences.py"
    [exclusions]="exclusions.py"
    [all]="all"
)

# ------------------------------------------------------------
# Parse arguments
COMMAND="${1:-}"
RESOURCE="${2:-}"

if [[ -z "$COMMAND" || "$COMMAND" == "help" ]]; then
    usage
    exit 0
fi

if [[ "$COMMAND" == "test" ]]; then
    echo "Running test"
    python "scripts/tests/$RESOURCE.py"
    exit 0
fi

if [[ "$COMMAND" == "script" ]]; then
    echo "Running script"
    python "scripts/actions/$RESOURCE.py"
    exit 0
fi

if [[ "$COMMAND" == "schema" ]]; then
    echo "updating schema"
    python "scripts/actions/update_schema.py"
    exit 0
fi

# --- Orders command ---
if [[ "$COMMAND" == "orders" ]]; then
    SUBCOMMAND="${2:-}"
    shift 2 2>/dev/null || true

    case "$SUBCOMMAND" in
        "")
            echo "Generating orders..."
            python scripts/actions/register_orders.py
            echo "Logging order emails..."
            python scripts/actions/send_orders.py
            ;;
        generate)
            echo "Generating orders..."
            python scripts/actions/register_orders.py "$@"
            ;;
        preview)
            echo "Previewing order emails..."
            python scripts/actions/send_orders.py --preview
            ;;
        send)
            echo "Logging order emails..."
            python scripts/actions/send_orders.py
            ;;
        *)
            echo "[ERROR] Unknown orders subcommand: $SUBCOMMAND"
            echo "Use: orders generate|preview|send"
            exit 1
            ;;
    esac
    exit 0
fi

# --- Webapp host ---
if [[ "$COMMAND" == "host" ]]; then
    python scripts/actions/host_webapp.py "${@:2}"
    exit 0
fi

# --- QR code generation ---
if [[ "$COMMAND" == "qr" ]]; then
    echo "Generating QR codes..."
    python scripts/actions/generate_qr.py "${@:2}"
    exit 0
fi

# --- Migration ---
if [[ "$COMMAND" != "migrate" ]]; then
    usage
    exit 1
fi

# If no resource supplied, default to "all"
if [[ -z "$RESOURCE" ]]; then
    RESOURCE="all"
fi

# ------------------------------------------------------------
# Run a single migration script
run_one() {
    local script_path="$1"
    local name="$(basename "$script_path" .py)"
    echo "Migrating $name"
    python "$script_path"
    local status=$?
    if (( status != 0 )); then
        echo "[WARNING] Migration of $script_path failed with exit code $status"
    fi
}

# ------------------------------------------------------------
# Main execution
if [[ "$RESOURCE" == "all" ]]; then
    echo "Migrating all resources"
    # Dietary Restrictions must run first — students.py and caterer_menus.py
    # both depend on it for name → record-id lookups.
    diet_script="$MIGRATION_DIR/dietary_restrictions.py"
    if [[ -f "$diet_script" ]]; then
        run_one "$diet_script"
    fi
    for script in "$MIGRATION_DIR"/*.py; do
        base="$(basename "$script")"
        [[ "$base" == "__init__.py" ]] && continue
        [[ "$base" == "dietary_restrictions.py" ]] && continue
        run_one "$script"
    done
else
    script_file="${RES_MAP[$RESOURCE]}"
    if [[ -z "$script_file" ]]; then
        echo "[ERROR] Unknown resource: $RESOURCE"
        usage
        exit 1
    fi

    script_path="$MIGRATION_DIR/$script_file"
    if [[ ! -f "$script_path" ]]; then
        echo "[ERROR] Migration script not found: $script_path"
        exit 1
    fi

    run_one "$script_path"
fi

exit 0

