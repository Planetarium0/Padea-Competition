#!/usr/bin/env bash
# ------------------------------------------------------------
# run – command-line shortcut for Padea operations
# ------------------------------------------------------------

MIGRATION_DIR="scripts/migrations"
SCRIPTS_DIR="scripts"

# Prefer the project-local venv; fall back to whatever is on PATH.
if [[ -f ".venv/bin/python" ]]; then
    PYTHON=".venv/bin/python"
else
    PYTHON="python"
fi

# Make both `scripts/` (so `support`, `actions`, etc. resolve as packages)
# and the project root (so `data.*` resolves) importable.
export PYTHONPATH=$PYTHONPATH:"$PWD":"$PWD"/"$SCRIPTS_DIR"

usage() {
    cat <<EOF
Usage:
  $0 migrate [resource] [--wipe] [--yes]
  $0 orders [generate [--dry-run]|preview|send] [--limit N]
  $0 forms qr [--origin URL] [--base-url URL] [--session ID] [--first]
  $0 forms qr send [--dry-run] [--first] [--limit N]
  $0 forms send {parents|students} [--dry-run] [--first] [--limit N]
  $0 caterer evaluate [--dry-run] [--limit N]
  $0 caterer switch <proposal_id> [--approve] [--dry-run]
  $0 dietary clarify [<caterer>] [--restriction NAME] [--dry-run]
  $0 dietary escalate [--dry-run]
  $0 dietary poll [--dry-run]
  $0 support poll [--dry-run]
  $0 emails retry [--dry-run] [--limit N]
  $0 procedure {start-of-term|weekly|polling} [--dry-run]
  $0 logs [index]
  $0 test [name]
  $0 script [name]
  $0 fix [--latest-error|--run-and-heal CMD|...]

migrate resources:
  diet, schools, caterers, contacts, menus, sessions, students, absences, exclusions, all

If no resource is supplied to migrate, all migrations run in dependency order.

procedure shortcuts:
  start-of-term  forms send parents --first, then forms qr send
  weekly         orders (generate + send), then caterer evaluate
  polling        support poll, dietary poll, dietary escalate, dietary clarify,
                 emails retry, then fix --latest-error (self-healing)

--limit N caps the number of emails the script will queue or retry (testing aid).
EOF
}

# Resolve short resource names to script filenames
declare -A RES_MAP=(
    [diet]="dietary_restrictions.py"
    [schools]="schools.py"
    [caterers]="caterers.py"
    [contacts]="caterer_contacts.py"
    [menus]="caterer_menus.py"
    [sessions]="sessions.py"
    [students]="students.py"
    [absences]="absences.py"
    [exclusions]="exclusions.py"
    [all]="all"
)

run_one() {
    local script_path="$1"
    local name
    name="$(basename "$script_path" .py)"
    echo "Migrating $name"
    $PYTHON "$script_path"
    local status=$?
    if (( status != 0 )); then
        echo "[WARNING] Migration of $script_path failed with exit code $status"
    fi
}

# ------------------------------------------------------------
COMMAND="${1:-}"

if [[ -z "$COMMAND" || "$COMMAND" == "help" ]]; then
    usage
    exit 0
fi

case "$COMMAND" in

    migrate)
        # Separate resource name from flags (flags start with --)
        if [[ -z "${2:-}" || "${2:-}" == --* ]]; then
            RESOURCE="all"
        else
            RESOURCE="${2}"
        fi

        EXTRA_FLAGS=()
        for arg in "${@:2}"; do
            case "$arg" in
                --wipe|--yes) EXTRA_FLAGS+=("$arg") ;;
            esac
        done

        case "$RESOURCE" in
            schema)
                echo "[INFO] 'migrate schema' is not applicable with Supabase — schema is managed via supabase/migrations/."
                ;;
            all)
                echo "Migrating all resources (dependency order)..."
                $PYTHON "$MIGRATION_DIR/migrate.py" "${EXTRA_FLAGS[@]}"
                ;;
            *)
                if [[ "${#EXTRA_FLAGS[@]}" -gt 0 ]]; then
                    echo "[WARNING] --wipe is only supported with 'migrate all'. Ignoring flags."
                fi
                script_file="${RES_MAP[$RESOURCE]}"
                if [[ -z "$script_file" ]]; then
                    echo "[ERROR] Unknown resource: $RESOURCE"
                    usage
                    exit 1
                fi
                script_path="$MIGRATION_DIR/$script_file"
                if [[ ! -f "$script_path" ]]; then
                    echo "[ERROR] Migration script not found: $script_path"
                    exit 1
                fi
                run_one "$script_path"
                ;;
        esac
        ;;

    orders)
        SUBCOMMAND="${2:-}"
        shift 2 2>/dev/null || true
        case "$SUBCOMMAND" in
            "")
                echo "Generating orders..."
                $PYTHON scripts/actions/orders/register_orders.py
                echo "Logging order emails..."
                $PYTHON scripts/actions/orders/send_orders.py "$@"
                ;;
            generate)
                echo "Generating orders..."
                $PYTHON scripts/actions/orders/register_orders.py "$@"
                ;;
            preview)
                echo "Previewing order emails..."
                $PYTHON scripts/actions/orders/send_orders.py --preview "$@"
                ;;
            send)
                echo "Logging order emails..."
                $PYTHON scripts/actions/orders/send_orders.py "$@"
                ;;
            *)
                echo "[ERROR] Unknown orders subcommand: $SUBCOMMAND"
                echo "Use: orders [generate [--dry-run]|preview|send]"
                exit 1
                ;;
        esac
        ;;

    forms)
        SUBCOMMAND="${2:-}"
        case "$SUBCOMMAND" in
            qr)
                if [[ "${3:-}" == "send" ]]; then
                    echo "Sending QR codes to site managers..."
                    $PYTHON scripts/actions/forms/send_qr_emails.py "${@:4}"
                else
                    echo "Generating QR codes..."
                    $PYTHON scripts/actions/forms/generate_qr.py "${@:3}"
                fi
                ;;
            send)
                TARGET="${3:-}"
                case "$TARGET" in
                    parents|students)
                        echo "Sending meal preference links to ${TARGET}..."
                        $PYTHON scripts/actions/forms/send_meals_links.py --target "$TARGET" "${@:4}"
                        ;;
                    *)
                        echo "[ERROR] Usage: $0 forms send {parents|students} [--immediate] [--dry-run]"
                        exit 1
                        ;;
                esac
                ;;
            *)
                echo "[ERROR] Unknown forms subcommand: ${SUBCOMMAND:-<none>}"
                echo "Use: forms qr [send] | forms send {parents|students}"
                exit 1
                ;;
        esac
        ;;

    caterer)
        SUBCOMMAND="${2:-}"
        case "$SUBCOMMAND" in
            evaluate)
                echo "Evaluating caterer ratings..."
                $PYTHON scripts/actions/caterers/evaluate_caterers.py "${@:3}"
                ;;
            switch)
                PROPOSAL_ID="${3:-}"
                if [[ -z "$PROPOSAL_ID" ]]; then
                    echo "[ERROR] Usage: $0 caterer switch <proposal_record_id> [--approve] [--dry-run]"
                    exit 1
                fi
                echo "Executing caterer switch for proposal $PROPOSAL_ID..."
                $PYTHON scripts/actions/caterers/execute_caterer_switch.py "$PROPOSAL_ID" "${@:4}"
                ;;
            *)
                echo "[ERROR] Unknown caterer subcommand: ${SUBCOMMAND:-<none>}"
                echo "Use: caterer evaluate | caterer switch <proposal_id>"
                exit 1
                ;;
        esac
        ;;

    dietary)
        SUBCOMMAND="${2:-}"
        case "$SUBCOMMAND" in
            clarify)
                CATERER="${3:-}"
                if [[ -z "$CATERER" || "$CATERER" == --* ]]; then
                    echo "Running dietary clarification sweep for all caterers..."
                    $PYTHON scripts/actions/dietary/clarify_dietary.py "${@:3}"
                else
                    echo "Running dietary clarification sweep for '$CATERER'..."
                    $PYTHON scripts/actions/dietary/clarify_dietary.py "$CATERER" "${@:4}"
                fi
                ;;
            escalate)
                echo "Running dietary escalation check..."
                $PYTHON scripts/actions/dietary/escalate_dietary.py "${@:3}"
                ;;
            poll)
                echo "Polling dietary inbound inbox..."
                $PYTHON scripts/actions/dietary/poll_dietary_inbox.py "${@:3}"
                ;;
            *)
                echo "[ERROR] Unknown dietary subcommand: ${SUBCOMMAND:-<none>}"
                echo "Use: dietary clarify <caterer> | dietary escalate | dietary poll [--dry-run]"
                exit 1
                ;;
        esac
        ;;

    support)
        SUBCOMMAND="${2:-}"
        case "$SUBCOMMAND" in
            poll)
                echo "Running support inbox poll..."
                $PYTHON scripts/actions/inbox/poll_support_inbox.py "${@:3}"
                ;;
            *)
                echo "[ERROR] Unknown support subcommand: ${SUBCOMMAND:-<none>}"
                echo "Use: support poll [--dry-run]"
                exit 1
                ;;
        esac
        ;;

    emails)
        SUBCOMMAND="${2:-}"
        case "$SUBCOMMAND" in
            retry)
                echo "Retrying failed emails..."
                $PYTHON scripts/actions/emails/retry_failed_emails.py "${@:3}"
                ;;
            *)
                echo "[ERROR] Unknown emails subcommand: ${SUBCOMMAND:-<none>}"
                echo "Use: emails retry [--dry-run] [--limit N]"
                exit 1
                ;;
        esac
        ;;

    test)
        if [[ "${2:-}" == "webapp" ]]; then
            (cd webapp && npm test)
        elif [[ -z "${2:-}" ]]; then
            $PYTHON scripts/tests/run_all.py
        else
            $PYTHON "scripts/tests/$2.py"
        fi
        ;;

    script)
        $PYTHON "scripts/actions/${2:-}.py"
        ;;

    logs)
        $PYTHON scripts/tools/view_llm_logs.py "${@:2}"
        ;;

    fix)
        shift
        $PYTHON scripts/tools/run_claude_agent.py "$@"
        ;;

    procedure)
        SUBCOMMAND="${2:-}"
        PASS_FLAGS=("${@:3}")

        run_step() {
            echo "==> $*"
            "$0" "$@"
            local rc=$?
            if (( rc != 0 )); then
                echo "[ERROR] Step '$*' failed (exit $rc). Aborting procedure."
                exit $rc
            fi
        }

        case "$SUBCOMMAND" in
            start-of-term)
                run_step forms send parents --first "${PASS_FLAGS[@]}"
                run_step forms qr send "${PASS_FLAGS[@]}"
                ;;
            weekly)
                run_step orders "${PASS_FLAGS[@]}"
                run_step caterer evaluate "${PASS_FLAGS[@]}"
                ;;
            polling)
                run_step support poll "${PASS_FLAGS[@]}"
                run_step dietary poll "${PASS_FLAGS[@]}"
                run_step dietary escalate "${PASS_FLAGS[@]}"
                run_step dietary clarify "${PASS_FLAGS[@]}"
                run_step emails retry "${PASS_FLAGS[@]}"
                # Attempt self-healing on any captured failure from this run.
                "$0" fix --latest-error || true
                ;;
            *)
                echo "[ERROR] Unknown procedure: ${SUBCOMMAND:-<none>}"
                echo "Use: procedure {start-of-term|weekly|polling} [--dry-run]"
                exit 1
                ;;
        esac
        ;;

    *)
        echo "[ERROR] Unknown command: $COMMAND"
        usage
        exit 1
        ;;

esac

exit 0
